# ============================================
# BEUBlog Backend Yapılandırması
# ============================================

# MongoDB Bağlantısı
# ------------------
# 3 seçenekten birini kullanabilirsiniz:

# Seçenek 1: Yerel MongoDB (Bilgisayarınızda MongoDB kuruluysa)
MONGO_URI=mongodb://localhost:27017/beublog

# Seçenek 2: MongoDB Atlas (Ücretsiz bulut veritabanı)
# https://www.mongodb.com/cloud/atlas adresinden hesap oluşturun
# MONGO_URI=mongodb+srv://kullanici:sifre@cluster0.xxxxx.mongodb.net/beublog?retryWrites=true&w=majority

# Seçenek 3: In-Memory MongoDB (Test için - sunucu kapanınca veriler silinir)
# MONGO_URI satırını yorum yapın veya silin, otomatik olarak in-memory kullanılır

# ============================================

# JWT Secret Key
# --------------
# ÖNEMLİ: Production'da bu değeri mutlaka değiştirin!
JWT_SECRET=your-super-secret-jwt-key-change-this

# Sunucu Portu
# ------------
PORT=5000
